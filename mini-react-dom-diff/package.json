{
  "name": "virtual-dom-diff-lab",
  "version": "0.1.0",
  "description": "A small virtual DOM and fiber commit engine that can be embedded in browser apps.",
  "keywords": [
    "virtual-dom",
    "fiber",
    "dom-diff",
    "vite"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./vdom": "./dist/vdom.js",
    "./fiber": "./dist/fiber.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --mode demo",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
